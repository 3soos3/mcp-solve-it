# .dockerignore — optimise Docker build context
# Excludes files that are not needed inside the image, reducing build time
# and preventing accidental inclusion of secrets or test data.

# ============================================================================
# Git and Version Control
# ============================================================================
.git
.gitignore
.gitattributes
.github

# ============================================================================
# Documentation
# ============================================================================
*.md
!README.md
docs/

# ============================================================================
# Tests and Development
# ============================================================================
tests/
test_*.py
*_test.py
.pytest_cache/
.coverage
htmlcov/
coverage.xml
.tox/
.nox/

# ============================================================================
# Python build artefacts
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
*.egg-info/
dist/
build/

# Type checking and linting caches
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# ============================================================================
# IDE and Editor Files
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# CI/CD
# ============================================================================
.github/
*.yml
*.yaml
!docker-compose*.yml

# ============================================================================
# Docker Files (prevent recursion)
# ============================================================================
Dockerfile*
.dockerignore
docker-compose*.yml

# ============================================================================
# Logs and Temporary Files
# ============================================================================
*.log
logs/
tmp/
temp/
*.tmp

# ============================================================================
# Environment and Secrets
# ============================================================================
.env
.env.*
*.pem
*.key
credentials.json
secrets/
