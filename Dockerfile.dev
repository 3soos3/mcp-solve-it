# Development Dockerfile for fss-mcp-solve-it (SOLVE-IT MCP Server)
# Includes development tools and installs fss-mcp/fss-core from source for
# hot-reload. Not optimised for production — use Dockerfile instead.

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates build-essential vim \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r mcpuser -g 1000 && \
    useradd -r -u 1000 -g mcpuser -m -s /bin/bash mcpuser

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src/ src/

# Install fss-core and fss-mcp from source, then the project deps.
# Mount the repo root as a volume so code changes take effect without rebuild.
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
        "fss-core @ git+https://github.com/3soos3/fss-chassis.git#subdirectory=packages/fss-core" \
        "fss-mcp[http,auth,otel] @ git+https://github.com/3soos3/fss-chassis.git#subdirectory=packages/fss-mcp" \
        pybtex xlsxwriter "rdflib>=7.0.0" pyyaml "pydantic>=2.0.0" && \
    pip install --no-cache-dir --no-deps -e .

COPY --chown=mcpuser:mcpuser config/ /app/config/

RUN git clone --depth 1 https://github.com/SOLVE-IT-DF/solve-it.git /app/solve-it-main && \
    rm -rf /app/solve-it-main/.git && \
    chown -R mcpuser:mcpuser /app/solve-it-main

USER mcpuser

ENV PYTHONPATH=/app/src \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    MCP_CHASSIS_CONFIG=/app/config/default.toml \
    SOLVE_IT_DATA_PATH=/app/solve-it-main/data \
    MCP_TRANSPORT=stdio \
    MCP_OTEL_ENABLED=false \
    ENVIRONMENT=development \
    LOG_LEVEL=DEBUG \
    LOG_FORMAT=text

EXPOSE 8000

ENTRYPOINT ["python", "-m", "fss_mcp"]
